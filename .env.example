# Site URL (used for SEO metadata, sitemap, etc.)
# NEXT_PUBLIC_SITE_URL=https://www.cfont.site

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=your-stripe-secret-key

# Supabase Configuration (Auth + Database)
# Get these from your Supabase project dashboard → Settings → API
# https://supabase.com/dashboard/project/your-project-id/settings/api
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Setup in Supabase Dashboard:
# 1. Go to Authentication → Providers → Google
# 2. Enable Google provider
# 3. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 4. Set Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
# 5. Copy Client ID and Client Secret into Supabase Google provider settings

# Cloudflare R2 Configuration
# Upload font files to R2 and set the public bucket URL below.
# Font file paths in fonts.json (e.g. "fonts/xxx.ttf") will be
# automatically prefixed with this URL.
# NEXT_PUBLIC_FONTS_CDN_URL=https://your-bucket.r2.dev/

# R2 Account credentials (for upload scripts only, not needed at runtime)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY=your-access-key
# R2_SECRET_KEY=your-secret-key
# R2_BUCKET=your-bucket-name
